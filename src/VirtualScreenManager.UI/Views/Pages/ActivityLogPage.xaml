<Page x:Class="VirtualScreenManager.UI.Views.Pages.ActivityLogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}">

  <Grid Margin="24,16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Header -->
    <ui:TextBlock Grid.Row="0"
                  Text="Activity Log"
                  FontTypography="Title"
                  Margin="0,0,0,16" />

    <!-- Command Bar -->
    <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                Margin="0,0,0,12">
      <ui:Button Content="All"
                 Command="{Binding ViewModel.SetFilterCommand}"
                 CommandParameter="Trace"
                 Margin="0,0,4,0">
        <ui:Button.Style>
          <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
            <Setter Property="Appearance" Value="Secondary" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding ViewModel.IsAllSelected}" Value="True">
                <Setter Property="Appearance" Value="Primary" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </ui:Button.Style>
      </ui:Button>
      <ui:Button Content="Info"
                 Command="{Binding ViewModel.SetFilterCommand}"
                 CommandParameter="Information"
                 Margin="0,0,4,0">
        <ui:Button.Style>
          <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
            <Setter Property="Appearance" Value="Secondary" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding ViewModel.IsInfoSelected}" Value="True">
                <Setter Property="Appearance" Value="Primary" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </ui:Button.Style>
      </ui:Button>
      <ui:Button Content="Warning"
                 Command="{Binding ViewModel.SetFilterCommand}"
                 CommandParameter="Warning"
                 Margin="0,0,4,0">
        <ui:Button.Style>
          <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
            <Setter Property="Appearance" Value="Secondary" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding ViewModel.IsWarningSelected}" Value="True">
                <Setter Property="Appearance" Value="Primary" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </ui:Button.Style>
      </ui:Button>
      <ui:Button Content="Error"
                 Command="{Binding ViewModel.SetFilterCommand}"
                 CommandParameter="Error"
                 Margin="0,0,16,0">
        <ui:Button.Style>
          <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
            <Setter Property="Appearance" Value="Secondary" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding ViewModel.IsErrorSelected}" Value="True">
                <Setter Property="Appearance" Value="Primary" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </ui:Button.Style>
      </ui:Button>

      <ui:Button Content="Clear"
                 Icon="{ui:SymbolIcon Delete24}"
                 Command="{Binding ViewModel.ClearLogCommand}"
                 Margin="0,0,4,0" />
      <ui:Button Content="Copy"
                 Icon="{ui:SymbolIcon Copy24}"
                 Command="{Binding ViewModel.CopyLogCommand}" />
    </StackPanel>

    <!-- Log List -->
    <ListView Grid.Row="2"
              ItemsSource="{Binding ViewModel.FilteredEntries}"
              VirtualizingPanel.IsVirtualizing="True"
              VirtualizingPanel.VirtualizationMode="Recycling">
      <ListView.ItemTemplate>
        <DataTemplate>
          <Grid Margin="4,4">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="70" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="80" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ui:TextBlock Grid.Column="0"
                          Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}"
                          Appearance="Secondary"
                          VerticalAlignment="Center" />

            <ui:InfoBadge Grid.Column="1"
                          Severity="{Binding Level, Converter={StaticResource LogLevelToSeverityConverter}}"
                          Margin="0,0,8,0"
                          VerticalAlignment="Center" />

            <ui:TextBlock Grid.Column="2"
                          Text="{Binding Category}"
                          FontTypography="BodyStrong"
                          VerticalAlignment="Center" />

            <ui:TextBlock Grid.Column="3"
                          Text="{Binding Message}"
                          TextWrapping="Wrap"
                          VerticalAlignment="Center" />
          </Grid>
        </DataTemplate>
      </ListView.ItemTemplate>
    </ListView>
  </Grid>

</Page>
