<Page x:Class="VirtualScreenManager.UI.Views.Pages.DisplayManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:VirtualScreenManager.UI.Controls"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      ScrollViewer.CanContentScroll="False">

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="24,16">

      <!-- Header -->
      <Grid Margin="0,0,0,16">
        <ui:TextBlock Text="Display Management"
                      FontTypography="Title"
                      VerticalAlignment="Center" />
        <ui:Button Content="Windows Display Settings"
                   Icon="{ui:SymbolIcon Open24}"
                   Command="{Binding ViewModel.OpenWindowsDisplaySettingsCommand}"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center" />
      </Grid>

      <!-- Monitor Topology -->
      <ui:Card Margin="0,0,0,16"
               Padding="0">
        <controls:MonitorTopologyControl Monitors="{Binding ViewModel.AllMonitors}"
                                         Height="220" />
      </ui:Card>

      <!-- Display Count Control -->
      <ui:Card Margin="0,0,0,16">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Column="0"
                      VerticalAlignment="Center">
            <ui:TextBlock Text="Virtual Display Count"
                          FontTypography="BodyStrong" />
            <ui:TextBlock Text="Set the number of virtual displays (1-16)"
                          Appearance="Secondary" />
          </StackPanel>

          <ui:NumberBox Grid.Column="1"
                        Value="{Binding ViewModel.DisplayCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Minimum="1"
                        Maximum="16"
                        SpinButtonPlacementMode="Inline"
                        Width="150"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center" />

          <ui:Button Grid.Column="2"
                     Content="Apply"
                     Appearance="Primary"
                     Command="{Binding ViewModel.SetDisplayCountCommand}"
                     VerticalAlignment="Center" />
        </Grid>
      </ui:Card>

      <!-- Loading indicator -->
      <ui:ProgressRing IsIndeterminate="True"
                       Width="32" Height="32"
                       Margin="0,0,0,16">
        <ui:ProgressRing.Style>
          <Style TargetType="ui:ProgressRing">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding ViewModel.IsUpdating}" Value="True">
                <Setter Property="Visibility" Value="Visible" />
              </DataTrigger>
              <DataTrigger Binding="{Binding ViewModel.IsRefreshing}" Value="True">
                <Setter Property="Visibility" Value="Visible" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </ui:ProgressRing.Style>
      </ui:ProgressRing>

      <!-- All Monitors -->
      <ui:TextBlock Text="Current Displays"
                    FontTypography="BodyStrong"
                    Margin="0,0,0,12" />

      <ItemsControl ItemsSource="{Binding ViewModel.AllMonitors}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <ui:Card Margin="0,0,0,8">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ui:SymbolIcon Grid.Column="0"
                               Symbol="Desktop24"
                               FontSize="28"
                               Margin="0,0,16,0"
                               VerticalAlignment="Center" />

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center">
                  <StackPanel Orientation="Horizontal">
                    <ui:TextBlock Text="{Binding AdapterName}"
                                  FontTypography="BodyStrong" />
                    <ui:TextBlock Text=" (Primary)"
                                  FontTypography="BodyStrong"
                                  Foreground="{DynamicResource SystemFillColorSuccessBrush}"
                                  Visibility="{Binding IsPrimary, Converter={StaticResource BooleanToVisibilityConverter}}"
                                  Margin="4,0,0,0" />
                  </StackPanel>
                  <ui:TextBlock Appearance="Secondary">
                    <ui:TextBlock.Text>
                      <MultiBinding StringFormat="{}{0}x{1} @ {2}Hz — {3}">
                        <Binding Path="Width" />
                        <Binding Path="Height" />
                        <Binding Path="RefreshRate" />
                        <Binding Path="DeviceName" />
                      </MultiBinding>
                    </ui:TextBlock.Text>
                  </ui:TextBlock>
                </StackPanel>

                <Border Grid.Column="2"
                        CornerRadius="4"
                        Padding="8,2"
                        VerticalAlignment="Center"
                        Background="{DynamicResource ControlFillColorDefaultBrush}">
                  <ui:TextBlock Text="{Binding IsVirtual, Converter={StaticResource VirtualLabelConverter}}"
                                FontSize="11"
                                Appearance="Secondary" />
                </Border>
              </Grid>
            </ui:Card>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

    </StackPanel>
  </ScrollViewer>

</Page>
