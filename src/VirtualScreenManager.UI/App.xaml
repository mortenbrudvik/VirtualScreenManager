<Application x:Class="VirtualScreenManager.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:VirtualScreenManager.UI.Converters"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ui:ThemesDictionary Theme="Dark" />
        <ui:ControlsDictionary />
      </ResourceDictionary.MergedDictionaries>

      <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
      <!-- Monitor topology brushes -->
      <SolidColorBrush x:Key="TopologyVirtualFillBrush" Color="#2860A5FA" />
      <SolidColorBrush x:Key="TopologyPhysicalFillBrush" Color="#289CA3AF" />
      <SolidColorBrush x:Key="TopologyVirtualBorderBrush" Color="#C860A5FA" />
      <SolidColorBrush x:Key="TopologyPhysicalBorderBrush" Color="#C89CA3AF" />
      <SolidColorBrush x:Key="TopologyPrimaryBorderBrush" Color="#DC34D399" />
      <SolidColorBrush x:Key="TopologyTextBrush" Color="#DCFFFFFF" />
      <SolidColorBrush x:Key="TopologySubtextBrush" Color="#8CFFFFFF" />

      <converters:BoolToBrushConverter x:Key="BoolToBrushConverter" />
      <converters:BoolToStatusConverter x:Key="BoolToStatusConverter" />
      <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
      <converters:LogLevelToSeverityConverter x:Key="LogLevelToSeverityConverter" />
      <converters:VirtualLabelConverter x:Key="VirtualLabelConverter" />
      <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
    </ResourceDictionary>
  </Application.Resources>
</Application>
